# Firebase config - get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Production Render backend URL.
# Set RENDER_BACKEND_URL in Vercel or local env to the Render deployment host.
RENDER_BACKEND_URL=https://your-render-backend-url
VITE_API_BASE_URL=${RENDER_BACKEND_URL}
